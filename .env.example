# Supabase - Configurar en Vercel: Project Settings > Environment Variables
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=eyJhbGrtrt.....

# Admin panel - credenciales para /login
ADMIN_USER=admin
ADMIN_PASSWORD=admin222

# JWT - clave secreta para firmar tokens de admin (mínimo 16 caracteres, diferente a ADMIN_PASSWORD)
JWT_SECRET=generar_una_clave_aleatoria_de_32_caracteres
