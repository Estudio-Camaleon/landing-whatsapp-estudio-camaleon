{
  "version": 2,
  "nodeVersion": "20.x",
  "rewrites": [
    {
      "source": "/assign-vendor",
      "destination": "/api/assign-vendor"
    },
    {
      "source": "/get-stats",
      "destination": "/api/get-stats"
    },
    {
      "source": "/get-vendors",
      "destination": "/api/get-vendors"
    },
    {
      "source": "/auth/login",
      "destination": "/api/auth/login"
    },
    {
      "source": "/login",
      "destination": "/apps/admin/login.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
